datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  category  String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
