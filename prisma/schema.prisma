// prisma/schema.prisma

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  category    String   // e.g., Food, Rent, Transport
  date        DateTime @default(now())
}